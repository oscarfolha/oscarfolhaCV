{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "nodeVersion": "20.x",
  "env": [
    {
      "key": "NEXT_PUBLIC_SITE_URL",
      "description": "The public URL of the deployed site",
      "value": "",
      "type": "plain"
    }
  ],
  "regions": ["iad1"],
  "functions": {
    "api/**": {
      "maxDuration": 10
    }
  }
}
